# Monarch Money MCP — environment variables
# Copy this to .env and fill in values before running.

# ── Monarch Money Auth ────────────────────────────────────────────────────────
# Preferred: paste your Monarch bearer token here for a stateless container.
# Get it on first run: docker compose up, then GET /api/token (with API key).
MONARCH_TOKEN=

# Fallback: email + password login (used when MONARCH_TOKEN is blank).
MONARCH_EMAIL=
MONARCH_PASSWORD=

# ── Server Auth ───────────────────────────────────────────────────────────────
# All endpoints require: Authorization: Bearer <this value>
# Generate with: openssl rand -hex 32
MCP_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
PORT=8000
