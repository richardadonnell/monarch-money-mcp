# Monarch Money MCP Server — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Auth method 1 (preferred, stateless) ──────────────────────────────────────
# Inject the Monarch bearer token directly. Avoids login on every container start.
# Obtain it via: GET /api/token after logging in once with email/password below.
MONARCH_TOKEN=

# ── Auth method 2 (fallback, logs in on startup) ──────────────────────────────
MONARCH_EMAIL=
MONARCH_PASSWORD=

# 2FA / TOTP secret key (Base32 seed, NOT the 6-digit rotating code).
# Required if your Monarch account has 2FA enabled.
#
# How to find it:
#   Option A — 1Password:
#     Open the Monarch login entry → edit it → OTP field → "Copy Secret Key"
#     It looks like: JBSWY3DPEHPK3PXP  (uppercase Base32, ~20–32 chars)
#
#   Option B — Monarch website:
#     Settings → Security → Two-factor authentication → "Two-factor text code"
#     (this is the raw seed shown when you first set up 2FA)
#
# Leave blank if your account does NOT have 2FA enabled.
MONARCH_MFA_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
# API key that protects all /api/* and /mcp endpoints.
# Use a long random string: python -c "import secrets; print(secrets.token_hex(32))"
MCP_API_KEY=

# Port the server listens on (default: 8000)
PORT=8000
